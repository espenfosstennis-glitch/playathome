# Kopier denne til .env.local og fyll inn verdiene fra Sanity-prosjektet.
# (.env.local er git-ignorert og skal ikke pushes.)

# Fra sanity.io/manage -> prosjektet -> Project ID
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Privat dataset: lesetoken som appen bruker server-side for å hente innhold.
# Sanity manage -> API -> Tokens -> Add API token -> Viewer (kun lesing).
# Denne legges også i Vercel (Environment Variables), men ALDRI som NEXT_PUBLIC.
SANITY_API_READ_TOKEN=

# Kun for engangs-import (scripts/seed.ts), brukes lokalt, IKKE i Vercel:
# Sanity manage -> API -> Tokens -> Add API token -> Editor (skriving).
SANITY_API_WRITE_TOKEN=

# --- Supabase (Fase 3) ---
# Fra Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role-nøkkelen legges ALDRI her eller i NEXT_PUBLIC. Kun server-side ved behov.
